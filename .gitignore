# 编译产物
build/
*.o
*.out
*.exe

# 系统文件
.DS_Store
.vscode/settings.json

# 临时文件
*~
*.swp
*.tmp

# 日志文件
*.log

# IDE 配置
.idea/
*.iml

# 空目录占位符（保留 .gitkeep）
!**/.gitkeep

# 忽略 solutions/cpp 目录下的编译产物（无扩展名文件）
# 匹配包含中文或下划线但没有扩展名的文件
solutions/cpp/[0-9]*_*[!.]*
solutions/cpp/[0-9]*_*
!solutions/cpp/*.cpp
!solutions/cpp/*.h
